# Copiar para .env e preencher. O .env nunca vai para o git.

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/auth/spotify/callback

# App
# SECRET_KEY: chave Fernet que encripta os tokens OAuth na BD.
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
# ADMIN_PASSWORD_HASH: hash bcrypt da password do painel admin.
ADMIN_PASSWORD_HASH=
DATABASE_URL=sqlite:///./backend/dashboard.db
LOCATION_LAT=41.1579   # Porto, Portugal
LOCATION_LON=-8.6291
