# Copiar para .env e preencher. O .env nunca vai para o git.

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/auth/spotify/callback

# App
# SECRET_KEY: chave Fernet que encripta os tokens OAuth na BD.
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
# ADMIN_PASSWORD_HASH: hash bcrypt da password do painel admin.
ADMIN_PASSWORD_HASH=
DATABASE_URL=sqlite:///./backend/dashboard.db
LOCATION_LAT=41.1579   # Porto, Portugal
LOCATION_LON=-8.6291
# Rótulos das contas Google no dashboard (email -> nome). JSON numa linha.
ACCOUNT_LABELS={"trabalho@empresa.com": "Work", "pessoal@gmail.com": "Pessoal"}
# Títulos de eventos a esconder dos próximos eventos (substring, case-insensitive).
CALENDAR_HIDE=["Daily Scrum"]
# Só mostrar eventos dentro destes N dias (evita recorrentes a anos de distância).
CALENDAR_HORIZON_DAYS=30
